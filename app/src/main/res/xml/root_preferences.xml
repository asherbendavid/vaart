<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <ListPreference
        android:key="pref_speed_unit"
        android:title="Speed unit"
        android:summary="%s"
        android:entries="@array/speed_unit_entries"
        android:entryValues="@array/speed_unit_values"
        android:defaultValue="region" />

    <SwitchPreferenceCompat
        android:key="pref_show_battery_pct"
        android:title="Show battery percentage"
        android:summary="Display the % text next to the battery icon"
        android:defaultValue="true" />

    <SwitchPreferenceCompat
        android:key="pref_hide_status_bar"
        android:title="Hide status bar"
        android:summary="Maximize screen space on the main display"
        android:defaultValue="false" />

    <ListPreference
        android:key="pref_audio_channel"
        android:title="Alert sound channel"
        android:summary="%s"
        android:entries="@array/audio_channel_entries"
        android:entryValues="@array/audio_channel_values"
        android:defaultValue="alarm" />

</PreferenceScreen>