<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.58"/>

    <!-- GPS indicator -->
    <TextView
        android:id="@+id/tvGpsStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No GPS"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:id="@+id/vGpsIndicator"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_indicator"
        android:layout_marginStart="4dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toEndOf="@id/tvGpsStatus"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Battery indicator -->
    <LinearLayout
        android:id="@+id/batteryShell"
        android:layout_width="wrap_content"
        android:layout_height="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:background="@drawable/battery_shell"
        android:layout_marginStart="10dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toEndOf="@id/vGpsIndicator"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/segBattery1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="1dp"
            android:background="@drawable/battery_segment"/>

        <View
            android:id="@+id/segBattery2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="1dp"
            android:background="@drawable/battery_segment"/>

        <View
            android:id="@+id/segBattery3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/battery_segment"/>
    </LinearLayout>

    <View
        android:id="@+id/batteryNub"
        android:layout_width="2dp"
        android:layout_height="5dp"
        android:background="@drawable/battery_nub"
        app:layout_constraintStart_toEndOf="@id/batteryShell"
        app:layout_constraintTop_toTopOf="@id/batteryShell"
        app:layout_constraintBottom_toBottomOf="@id/batteryShell"/>

    <TextView
        android:id="@+id/tvBatteryPct"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginStart="4dp"
        app:layout_constraintStart_toEndOf="@id/batteryNub"
        app:layout_constraintTop_toTopOf="@id/tvGpsStatus"/>

    <!-- Speed display -->
    <Button
        android:id="@+id/btnHud"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="HUD"
        android:textSize="12sp"
        android:textColor="#888888"
        android:backgroundTint="#1C1C2E"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        style="@style/Widget.AppCompat.Button.Borderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMenu"/>

    <Button
        android:id="@+id/btnMenu"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="☰"
        android:textSize="12sp"
        android:textColor="#888888"
        android:backgroundTint="#1C1C2E"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        style="@style/Widget.AppCompat.Button.Borderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline"/>

    <!-- Speed display area: min sign | speed | max sign -->
    <TextView
        android:id="@+id/tvMinSpeedSign"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/speed_limit_sign_min_bg"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/tvSpeed"
        app:layout_constraintBottom_toBottomOf="@id/tvSpeed"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="invisible"/>

    <View
        android:id="@+id/vMinSpeedLine"
        android:layout_width="64dp"
        android:layout_height="3dp"
        android:background="#F59E0B"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/tvMinSpeedSign"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvMaxSpeedSign"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:text="--"
        android:textColor="#000000"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/speed_limit_sign_bg"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/tvSpeed"
        app:layout_constraintBottom_toBottomOf="@id/tvSpeed"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        android:visibility="visible"/>

    <View
        android:id="@+id/vMaxSpeedLine"
        android:layout_width="64dp"
        android:layout_height="3dp"
        android:background="#CC0000"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/tvMaxSpeedSign"
        app:layout_constraintEnd_toStartOf="@id/guideline"/>

    <TextView
        android:id="@+id/tvSpeed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/tvUnit"
        app:layout_constraintEnd_toStartOf="@id/tvMaxSpeedSign"
        app:layout_constraintStart_toEndOf="@id/tvMinSpeedSign"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"/>

    <TextView
        android:id="@+id/tvUnit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="km/h"
        android:textColor="#888888"
        android:textSize="16sp"
        android:gravity="center"
        android:letterSpacing="0.2"
        app:layout_constraintBottom_toTopOf="@id/btnStartStop"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSpeed"/>

    <Button
        android:id="@+id/btnVehicleSelector"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Anonymous"
        android:textSize="11sp"
        android:textColor="#888888"
        android:backgroundTint="#1C1C2E"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:maxWidth="200dp"
        android:ellipsize="end"
        android:singleLine="true"
        style="@style/Widget.AppCompat.Button.Borderless"
        app:layout_constraintTop_toBottomOf="@id/tvGpsStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvOdometer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="000 000 km"
        android:textColor="#BBBBBB"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvUnit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline"/>

    <!-- START/STOP button -->
    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="START"
        android:textSize="13sp"
        android:backgroundTint="#0E4520"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Vertical divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#1C1C2E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Trips container: fills right half -->
    <LinearLayout
        android:id="@+id/tripsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#BBBBBB"
            android:textSize="30sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="10dp"/>

        <!-- Horizontal Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1C1C2E"/>

        <!-- Trip A -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIP A"
                android:textColor="#F59E0B"
                android:textSize="12sp"
                android:letterSpacing="0.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="this journey"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="top">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDistA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-light"/>

                    <TextView
                        android:id="@+id/tvTimeA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00:00"
                        android:textColor="#BBBBBB"
                        android:textSize="17sp"/>

                    <TextView
                        android:id="@+id/tvAvgA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h avg"
                        android:textColor="#BBBBBB"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tvMaxA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h max"
                        android:textColor="#BBBBBB"
                        android:textSize="15sp"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnResetA"
                    android:layout_width="wrap_content"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_height="wrap_content"
                    android:text="Reset"
                    android:textSize="11sp"
                    android:textColor="#F59E0B"
                    android:backgroundTint="#1C1C2E"
                    android:minWidth="80dp"
                    android:minHeight="48dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Horizontal divider between trips -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1C1C2E"/>

        <!-- Trip B -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIP B"
                android:textColor="#06B6D4"
                android:textSize="12sp"
                android:letterSpacing="0.15"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="since refuel"
                android:textColor="#444466"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="top">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDistB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-light"/>

                    <TextView
                        android:id="@+id/tvTimeB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00:00"
                        android:textColor="#BBBBBB"
                        android:textSize="17sp"/>

                    <TextView
                        android:id="@+id/tvAvgB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h avg"
                        android:textColor="#BBBBBB"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tvMaxB"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h max"
                        android:textColor="#BBBBBB"
                        android:textSize="15sp"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnResetB"
                    android:layout_width="wrap_content"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_height="wrap_content"
                    android:text="Reset"
                    android:textSize="11sp"
                    android:textColor="#06B6D4"
                    android:backgroundTint="#1C1C2E"
                    android:minWidth="80dp"
                    android:minHeight="48dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>